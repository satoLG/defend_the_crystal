# Supabase Realtime signaling for Trystero (optional).
#
# When both values are set, peers discover each other over a Supabase
# Realtime Broadcast channel you control — a much steadier handshake path
# than the public Nostr/torrent/MQTT relays, which stay on as backups.
# Leave them blank (or delete this file) and the game runs on the public
# relays exactly as before.
#
# Only the WebRTC handshake crosses Supabase; once peers link up, all
# gameplay data flows directly peer-to-peer.
#
# Where to find these: Supabase dashboard -> Project Settings -> API.
#   - VITE_SUPABASE_URL      = "Project URL"       (e.g. https://xxxx.supabase.co)
#   - VITE_SUPABASE_ANON_KEY = "anon public" key   (safe to ship in the client)
#
# Copy this file to `.env` and fill in your project's values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
