{
  "name": "defend-the-crystal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:server & npm run dev:web",
    "dev:web": "npm run dev --workspace @dtc/web",
    "dev:server": "npm run dev --workspace @dtc/server",
    "build": "npm run build --workspace @dtc/web",
    "start": "npm run start --workspace @dtc/server",
    "smoke": "npm run smoke --workspace @dtc/web"
  }
}
